# ================================================================
# WERKFLOW PORTAL CONFIGURATION
# ================================================================

# ----------------------------------------------------------------
# Service Configuration
# ----------------------------------------------------------------
NEXT_PUBLIC_APP_NAME=Werkflow Portal
NEXT_PUBLIC_APP_VERSION=1.0.0

# Port for the unified portal
PORT=4000

# ----------------------------------------------------------------
# Backend API URLs
# ----------------------------------------------------------------
# Flowable Engine Service
NEXT_PUBLIC_ENGINE_API_URL=http://localhost:8081

# Admin Service
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:8083/api

# Business Service (consolidated HR + Finance + Procurement + Inventory)
NEXT_PUBLIC_BUSINESS_API_URL=http://localhost:8084/api
NEXT_PUBLIC_HR_API_URL=http://localhost:8084/api
NEXT_PUBLIC_FINANCE_API_URL=http://localhost:8084/api
NEXT_PUBLIC_PROCUREMENT_API_URL=http://localhost:8084/api
NEXT_PUBLIC_INVENTORY_API_URL=http://localhost:8084/api

# ----------------------------------------------------------------
# NextAuth Configuration
# ----------------------------------------------------------------
NEXTAUTH_URL=http://localhost:4000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# ----------------------------------------------------------------
# Keycloak Configuration
# ----------------------------------------------------------------
# OAuth2 Client Credentials (reuses admin-portal client, rename later)
KEYCLOAK_CLIENT_ID=werkflow-portal
KEYCLOAK_CLIENT_SECRET=your-client-secret-from-keycloak

# OAuth2 Issuer Configuration (Three-URL Strategy for Docker)
KEYCLOAK_ISSUER_INTERNAL=http://localhost:8090/realms/werkflow
KEYCLOAK_ISSUER_PUBLIC=http://localhost:8090/realms/werkflow
KEYCLOAK_ISSUER_BROWSER=http://localhost:8090/realms/werkflow

# ----------------------------------------------------------------
# Feature Flags
# ----------------------------------------------------------------
NEXT_PUBLIC_ENABLE_BPMN_DESIGNER=true
NEXT_PUBLIC_ENABLE_FORM_BUILDER=true
NEXT_PUBLIC_ENABLE_PROCESS_MONITORING=true
